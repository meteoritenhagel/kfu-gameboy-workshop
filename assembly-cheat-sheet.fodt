  <style:master-page style:name="Standard" style:page-layout-name="pm1" draw:style-name="dp1">
   <style:header>
    <text:p text:style-name="P1"><text:span text:style-name="T1">22.06.2026</text:span><text:span text:style-name="T2"><text:tab/></text:span><text:span text:style-name="T3">Hands-On Introduction to Game Boy Programming</text:span><text:span text:style-name="T2"><text:tab/></text:span><text:span text:style-name="T1">Dr. Tristan Repolusk</text:span></text:p>
   </style:header>
  </style:master-page>
 </office:master-styles>
 <office:body>
  <office:text text:use-soft-page-breaks="true">
   <text:sequence-decls>
    <text:sequence-decl text:display-outline-level="0" text:name="Illustration"/>
    <text:sequence-decl text:display-outline-level="0" text:name="Table"/>
    <text:sequence-decl text:display-outline-level="0" text:name="Text"/>
    <text:sequence-decl text:display-outline-level="0" text:name="Drawing"/>
    <text:sequence-decl text:display-outline-level="0" text:name="Figure"/>
   </text:sequence-decls>
   <text:p text:style-name="P2">WiFi Access:</text:p>
   <text:list text:style-name="L1">
    <text:list-item>
     <text:p text:style-name="P3">SSID: <text:span text:style-name="T4">[SSID]</text:span></text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P4">Username: <text:span text:style-name="T1">[</text:span><text:span text:style-name="T5">Username]</text:span></text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P4">Password: <text:span text:style-name="T5">[Password]</text:span></text:p>
    </text:list-item>
   </text:list>
   <text:p text:style-name="P5"/>
   <text:p text:style-name="P6">General</text:p>
   <text:p text:style-name="P7">Registers</text:p>
   <text:list text:style-name="L2">
    <text:list-item>
     <text:p text:style-name="P8">8-bit registers: <text:span text:style-name="T6">a, b, c, d, e, h, l, [hl]</text:span> (<text:span text:style-name="T1">a</text:span>ddress in 16-bit register <text:span text:style-name="T6">hl</text:span>)</text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P9">16-bit registers: <text:span text:style-name="T6">af</text:span> (<text:span text:style-name="T6">a </text:span>and flags register), <text:span text:style-name="T6">bc</text:span>, <text:span text:style-name="T6">de</text:span>, <text:span text:style-name="T6">hl</text:span></text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P10">Flags: <text:span text:style-name="T6">ZF</text:span> (zero flag) and <text:span text:style-name="T6">CF</text:span> (carry flag)</text:p>
     <text:p text:style-name="P11"><text:span text:style-name="T7"/></text:p>
    </text:list-item>
   </text:list>
   <text:p text:style-name="P12">Conditions</text:p>
   <table:table table:name="Table11" table:style-name="Table11">
    <table:table-column table:style-name="Table11.A"/>
    <table:table-row table:style-name="Table11.1">
     <table:table-cell table:style-name="Table11.A1" office:value-type="string">
      <text:p text:style-name="P13">cp a, 100 <text:s text:c="13"/>; calculate a – 100 and update ZF, CF</text:p>
      <text:p text:style-name="P13">jr z, .doIfEqual <text:s text:c="6"/>; jumps if a == 100</text:p>
      <text:p text:style-name="P13">jr nz, .doIfNotEqual <text:s text:c="2"/>; jumps if a != 100</text:p>
      <text:p text:style-name="P13">jr c, .doIfSmaller <text:s text:c="4"/>; jumps if a &lt; <text:s/>100</text:p>
      <text:p text:style-name="P13">jr nc, .doIfGreaterEq <text:s/>; jumps if a &gt;= 100</text:p>
     </table:table-cell>
    </table:table-row>
   </table:table>
   <text:p text:style-name="P14"/>
   <text:p text:style-name="P14"/>
   <text:p text:style-name="P6">Exercise 01: Display and Graphics Setup</text:p>
   <text:p text:style-name="P15">Assembler</text:p>
   <table:table table:name="Table1" table:style-name="Table1">
    <table:table-column table:style-name="Table1.A"/>
    <table:table-column table:style-name="Table1.B"/>
    <table:table-row>
     <table:table-cell table:style-name="Table1.A1" office:value-type="string">
      <text:p text:style-name="P7">Defining a data section (<text:span text:style-name="T8">r</text:span>ead-<text:span text:style-name="T8">o</text:span>nly)</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="Table1.B1" office:value-type="string">
      <text:p text:style-name="P16">SECTION “title”, ROM0</text:p>
     </table:table-cell>
    </table:table-row>
    <table:table-row>
     <table:table-cell table:style-name="Table1.A2" office:value-type="string">
      <text:p text:style-name="P17">Include a binary</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="Table1.B2" office:value-type="string">
      <text:p text:style-name="P7"><text:span text:style-name="T9">INCBIN</text:span><text:span text:style-name="T10"> “./</text:span><text:span text:style-name="T9">build/title.2bpp“</text:span></text:p>
     </table:table-cell>
    </table:table-row>
    <table:table-row>
     <table:table-cell table:style-name="Table1.A2" office:value-type="string">
      <text:p text:style-name="P18">Defining a label (global)</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="Table1.B2" office:value-type="string">
      <text:p text:style-name="P16">GlobalLabel::</text:p>
     </table:table-cell>
    </table:table-row>
    <table:table-row>
     <table:table-cell table:style-name="Table1.A2" office:value-type="string">
      <text:p text:style-name="P18">Defining a label (file-specific)</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="Table1.B2" office:value-type="string">
      <text:p text:style-name="P16">FileSpecificLabel:</text:p>
     </table:table-cell>
    </table:table-row>
    <table:table-row>
     <table:table-cell table:style-name="Table1.A2" office:value-type="string">
      <text:p text:style-name="P18">Defining a label (local, routine-specific)</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="Table1.B2" office:value-type="string">
      <text:p text:style-name="P16">.localLabel</text:p>
     </table:table-cell>
    </table:table-row>
   </table:table>
   <text:p text:style-name="P14"/>
   <text:p text:style-name="P15">CPU Instructions</text:p>
   <table:table table:name="Table3" table:style-name="Table3">
    <table:table-column table:style-name="Table3.A"/>
    <table:table-column table:style-name="Table3.B"/>
    <table:table-row>
     <table:table-cell table:style-name="Table3.A1" office:value-type="string">
      <text:p text:style-name="P19">Call a routine</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="Table3.B1" office:value-type="string">
      <text:p text:style-name="P20"><text:span text:style-name="T11">c</text:span><text:span text:style-name="T12">all RoutineStart</text:span></text:p>
     </table:table-cell>
    </table:table-row>
    <table:table-row>
     <table:table-cell table:style-name="Table3.A2" office:value-type="string">
      <text:p text:style-name="P17">Return from routine</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="Table3.B2" office:value-type="string">
      <text:p text:style-name="P21">ret</text:p>
     </table:table-cell>
    </table:table-row>
    <table:table-row>
     <table:table-cell table:style-name="Table3.A2" office:value-type="string">
      <text:p text:style-name="P17">Load current vertical line into a</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="Table3.B2" office:value-type="string">
      <text:p text:style-name="P22">ld a, [rLY] <text:s/>; rLY = $FF44</text:p>
     </table:table-cell>
    </table:table-row>
    <table:table-row>
     <table:table-cell table:style-name="Table3.A2" office:value-type="string">
      <text:p text:style-name="P23">Jump to close location</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="Table3.B2" office:value-type="string">
      <text:p text:style-name="P20">jr .localLabel</text:p>
     </table:table-cell>
    </table:table-row>
    <table:table-row>
     <table:table-cell table:style-name="Table3.A2" office:value-type="string">
      <text:p text:style-name="P24">Update zero/carry flags for the value of a-10</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="Table3.B2" office:value-type="string">
      <text:p text:style-name="P25">cp 10 <text:s/>; calculates a - 10</text:p>
     </table:table-cell>
    </table:table-row>
    <table:table-row>
     <table:table-cell table:style-name="Table3.A2" office:value-type="string">
      <text:p text:style-name="P24">Jump to close location if carry flag is set</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="Table3.B2" office:value-type="string">
      <text:p text:style-name="P25">jr c, GlobalLabel</text:p>
     </table:table-cell>
    </table:table-row>
   </table:table>
   <text:p text:style-name="P26"/>
   <text:p text:style-name="P15">Memory Locations</text:p>
   <table:table table:name="Table4" table:style-name="Table4">
    <table:table-column table:style-name="Table4.A"/>
    <table:table-column table:style-name="Table4.B"/>
    <table:table-row table:style-name="Table4.1">
     <table:table-cell table:style-name="Table4.A1" office:value-type="string">
      <text:p text:style-name="P17">Vertical Line Register</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="Table4.B1" office:value-type="string">
      <text:p text:style-name="P22">rLY ; = $FF44</text:p>
     </table:table-cell>
    </table:table-row>
    <table:table-row table:style-name="Table4.1">
     <table:table-cell table:style-name="Table4.A1" office:value-type="string">
      <text:p text:style-name="P23">Tiles Cache 1</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="Table4.B1" office:value-type="string">
      <text:p text:style-name="P20">$9000</text:p>
     </table:table-cell>
    </table:table-row>
    <table:table-row table:style-name="Table4.3">
     <table:table-cell table:style-name="Table4.A1" office:value-type="string">
      <text:p text:style-name="P23">Tilemap Cache</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="Table4.B1" office:value-type="string">
      <text:p text:style-name="P27">TILEMAP0 <text:s/>; <text:span text:style-name="T13">= </text:span>$9800</text:p>
     </table:table-cell>
    </table:table-row>
    <table:table-row table:style-name="Table4.3">
     <table:table-cell table:style-name="Table4.A4" office:value-type="string">
      <text:p text:style-name="P23">LCD Control Register</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="Table4.B4" office:value-type="string">
      <text:p text:style-name="P20">rLCDC <text:s/>; = $FF40</text:p>
     </table:table-cell>
    </table:table-row>
   </table:table>
   <text:p text:style-name="P14"/>
   <text:p text:style-name="P14"/>
   <text:p text:style-name="P6"><text:soft-page-break/>Exercise 02: Change Palette</text:p>
   <text:p text:style-name="P28">CPU Instructions</text:p>
   <table:table table:name="Table6" table:style-name="Table6">
    <table:table-column table:style-name="Table6.A"/>
    <table:table-column table:style-name="Table6.B"/>
    <table:table-row>
     <table:table-cell table:style-name="Table6.A1" office:value-type="string">
      <text:p text:style-name="P23">Decrease a by 1 and update zero/<text:span text:style-name="T14">carry</text:span> flag<text:span text:style-name="T14">s</text:span></text:p>
     </table:table-cell>
     <table:table-cell table:style-name="Table6.B1" office:value-type="string">
      <text:p text:style-name="P29">dec a</text:p>
     </table:table-cell>
    </table:table-row>
    <table:table-row>
     <table:table-cell table:style-name="Table6.A2" office:value-type="string">
      <text:p text:style-name="P19">Return if zero flag is set</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="Table6.B2" office:value-type="string">
      <text:p text:style-name="P28"><text:span text:style-name="T15">r</text:span>et <text:span text:style-name="T15">z</text:span></text:p>
     </table:table-cell>
    </table:table-row>
   </table:table>
   <text:p text:style-name="P30"/>
   <text:p text:style-name="P28">Memory Locations</text:p>
   <table:table table:name="Table7" table:style-name="Table7">
    <table:table-column table:style-name="Table7.A"/>
    <table:table-column table:style-name="Table7.B"/>
    <table:table-row table:style-name="Table7.1">
     <table:table-cell table:style-name="Table7.A1" office:value-type="string">
      <text:p text:style-name="P23">Background palette</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="Table7.B1" office:value-type="string">
      <text:p text:style-name="P28"><text:span text:style-name="T10">r</text:span><text:span text:style-name="T16">BGP</text:span><text:span text:style-name="T10"> ; = $FF4</text:span><text:span text:style-name="T16">7</text:span></text:p>
     </table:table-cell>
    </table:table-row>
   </table:table>
   <text:p text:style-name="P31"/>
   <text:p text:style-name="P31"/>
   <text:p text:style-name="P32">Exercise 0<text:span text:style-name="T15">3</text:span>: React on Player Input</text:p>
   <text:p text:style-name="P33">CPU Instructions</text:p>
   <table:table table:name="Table8" table:style-name="Table8">
    <table:table-column table:style-name="Table8.A"/>
    <table:table-column table:style-name="Table8.B"/>
    <table:table-row>
     <table:table-cell table:style-name="Table8.A1" office:value-type="string">
      <text:p text:style-name="P34">Call the routine that updates the buttons</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="Table8.B1" office:value-type="string">
      <text:p text:style-name="P35">call UpdateKeys</text:p>
     </table:table-cell>
    </table:table-row>
    <table:table-row>
     <table:table-cell table:style-name="Table8.A2" office:value-type="string">
      <text:p text:style-name="P34">Load the value at address wCurKeys into a</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="Table8.B2" office:value-type="string">
      <text:p text:style-name="P36">ld a, [wCurKeys]</text:p>
     </table:table-cell>
    </table:table-row>
    <table:table-row>
     <table:table-cell table:style-name="Table8.A2" office:value-type="string">
      <text:p text:style-name="P34">Unset zero flag if start button flag is set in a</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="Table8.B2" office:value-type="string">
      <text:p text:style-name="P33">and a, PAD_START</text:p>
     </table:table-cell>
    </table:table-row>
    <table:table-row>
     <table:table-cell table:style-name="Table8.A2" office:value-type="string">
      <text:p text:style-name="P37">Jump to close location <text:span text:style-name="T8">if zero flag is not set</text:span></text:p>
     </table:table-cell>
     <table:table-cell table:style-name="Table8.B2" office:value-type="string">
      <text:p text:style-name="P38">jr <text:span text:style-name="T8">nz, </text:span>.localLabel</text:p>
     </table:table-cell>
    </table:table-row>
   </table:table>
   <text:p text:style-name="P39"/>
   <text:p text:style-name="P39"/>
   <text:p text:style-name="P6">Exercise 0<text:span text:style-name="T15">4</text:span>: <text:span text:style-name="T15">Add Music</text:span></text:p>
   <text:p text:style-name="P40">Assembler</text:p>
   <table:table table:name="Table5" table:style-name="Table5">
    <table:table-column table:style-name="Table5.A"/>
    <table:table-column table:style-name="Table5.B"/>
    <table:table-row>
     <table:table-cell table:style-name="Table5.A1" office:value-type="string">
      <text:p text:style-name="P41">Defining a <text:span text:style-name="T8">variable</text:span> section (<text:span text:style-name="T8">mutable</text:span>)</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="Table5.B1" office:value-type="string">
      <text:p text:style-name="P41"><text:span text:style-name="T10">SECTION “</text:span><text:span text:style-name="T17">variables</text:span><text:span text:style-name="T10">”, </text:span><text:span text:style-name="T17">W</text:span><text:span text:style-name="T10">R</text:span><text:span text:style-name="T17">A</text:span><text:span text:style-name="T10">M0</text:span></text:p>
     </table:table-cell>
    </table:table-row>
    <table:table-row>
     <table:table-cell table:style-name="Table5.A2" office:value-type="string">
      <text:p text:style-name="P42">Define a variable with one byte</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="Table5.B2" office:value-type="string">
      <text:p text:style-name="P43"><text:span text:style-name="T9">W</text:span><text:span text:style-name="T10">updateSound:: db</text:span></text:p>
     </table:table-cell>
    </table:table-row>
    <table:table-row>
     <table:table-cell table:style-name="Table5.A2" office:value-type="string">
      <text:p text:style-name="P42">Include a definitions file</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="Table5.B2" office:value-type="string">
      <text:p text:style-name="P44">INCLUDE &quot;./include/hUGE.inc&quot;</text:p>
     </table:table-cell>
    </table:table-row>
    <table:table-row>
     <table:table-cell table:style-name="Table5.A2" office:value-type="string">
      <text:p text:style-name="P42">Defining a data section at a specific address</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="Table5.B2" office:value-type="string">
      <text:p text:style-name="P44">SECTION &quot;<text:span text:style-name="T18">SctName</text:span>&quot;, ROM0[$0040]</text:p>
     </table:table-cell>
    </table:table-row>
   </table:table>
   <text:p text:style-name="P45"/>
   <text:p text:style-name="P40">CPU Instructions</text:p>
   <table:table table:name="Table9" table:style-name="Table9">
    <table:table-column table:style-name="Table9.A"/>
    <table:table-column table:style-name="Table9.B"/>
    <table:table-row>
     <table:table-cell table:style-name="Table9.A1" office:value-type="string">
      <text:p text:style-name="P46">Push value of 16-bit register onto stack</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="Table9.B1" office:value-type="string">
      <text:p text:style-name="P47">push af</text:p>
     </table:table-cell>
    </table:table-row>
    <table:table-row>
     <table:table-cell table:style-name="Table9.A2" office:value-type="string">
      <text:p text:style-name="P46">Restore value of 16-bit register from stack</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="Table9.B2" office:value-type="string">
      <text:p text:style-name="P48">pop af</text:p>
     </table:table-cell>
    </table:table-row>
    <table:table-row>
     <table:table-cell table:style-name="Table9.A2" office:value-type="string">
      <text:p text:style-name="P46">Load the VBlank interrupt flag</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="Table9.B2" office:value-type="string">
      <text:p text:style-name="P49">ld a, IE_VBLANK</text:p>
     </table:table-cell>
    </table:table-row>
    <table:table-row>
     <table:table-cell table:style-name="Table9.A2" office:value-type="string">
      <text:p text:style-name="P46">Activate/disable active interrupts</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="Table9.B2" office:value-type="string">
      <text:p text:style-name="P50">ld [rIE], a</text:p>
     </table:table-cell>
    </table:table-row>
    <table:table-row>
     <table:table-cell table:style-name="Table9.A2" office:value-type="string">
      <text:p text:style-name="P46">Enable interrupts in general</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="Table9.B2" office:value-type="string">
      <text:p text:style-name="P48">ei</text:p>
     </table:table-cell>
    </table:table-row>
    <table:table-row>
     <table:table-cell table:style-name="Table9.A2" office:value-type="string">
      <text:p text:style-name="P46">Return from interrupt handler</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="Table9.B2" office:value-type="string">
      <text:p text:style-name="P48">reti</text:p>
     </table:table-cell>
    </table:table-row>
   </table:table>
   <text:p text:style-name="P45"/>
   <text:p text:style-name="P40">Memory Locations</text:p>
   <table:table table:name="Table10" table:style-name="Table10">
    <table:table-column table:style-name="Table10.A"/>
    <table:table-column table:style-name="Table10.B"/>
    <table:table-row table:style-name="Table10.1">
     <table:table-cell table:style-name="Table10.A1" office:value-type="string">
      <text:p text:style-name="P42">Interrupt Register</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="Table10.B1" office:value-type="string">
      <text:p text:style-name="P51">rIE <text:s/>; = $FFFF</text:p>
     </table:table-cell>
    </table:table-row>
    <table:table-row table:style-name="Table10.1">
     <table:table-cell table:style-name="Table10.A1" office:value-type="string">
      <text:p text:style-name="P42">VBlank Interrupt Handler</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="Table10.B1" office:value-type="string">
      <text:p text:style-name="P51">INT_HANDLER_VBLANK <text:s/>; = $0040</text:p>
     </table:table-cell>
    </table:table-row>
    <table:table-row table:style-name="Table10.3">
     <table:table-cell table:style-name="Table10.A1" office:value-type="string">
      <text:p text:style-name="P42">Audio Master Control Register (NR52)</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="Table10.B1" office:value-type="string">
      <text:p text:style-name="P52"><text:span text:style-name="T13">r</text:span>AUDENA <text:s text:c="2"/>; = $FF26</text:p>
     </table:table-cell>
    </table:table-row>
    <table:table-row table:style-name="Table10.3">
     <table:table-cell table:style-name="Table10.A1" office:value-type="string">
      <text:p text:style-name="P42">Sound Panning Register (NR51)</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="Table10.B1" office:value-type="string">
      <text:p text:style-name="P53"><text:span text:style-name="T13">r</text:span>AUD<text:span text:style-name="T13">TERM</text:span> <text:s/>; = $FF2<text:span text:style-name="T13">5</text:span></text:p>
     </table:table-cell>
    </table:table-row>
    <table:table-row table:style-name="Table10.3">
     <table:table-cell table:style-name="Table10.A5" office:value-type="string">
      <text:p text:style-name="P42">Audio Master Volume (NR50)</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="Table10.B5" office:value-type="string">
      <text:p text:style-name="P53"><text:span text:style-name="T13">r</text:span>AUD<text:span text:style-name="T13">VOL</text:span> <text:s text:c="2"/>; = $FF2<text:span text:style-name="T13">4</text:span></text:p>
     </table:table-cell>
    </table:table-row>
   </table:table>
   <text:p text:style-name="P45"/>
  </office:text>
 </office:body>
</office:document>